/*
  # Security Headers
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  X-XSS-Protection: 1; mode=block
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(self), payment=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://www.googletagmanager.com https://www.google-analytics.com https://static.elfsight.com https://apps.elfsight.com https://maps.googleapis.com https://cdn.trustindex.io https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.trustindex.io; font-src 'self' https://fonts.gstatic.com https://cdn.trustindex.io; img-src 'self' data: https: blob:; connect-src 'self' https://www.google-analytics.com https://www.google.com https://apps.elfsight.com https://core.elfsight.com https://hooks.zapier.com https://crm.asap.repair https://maps.googleapis.com https://cdn.trustindex.io; frame-src https://apps.elfsight.com https://www.youtube.com; object-src 'none'; base-uri 'self'; form-action 'self' https://hooks.zapier.com

/components/*
  X-Robots-Tag: noindex, nofollow

/assets/rooms/_*
  X-Robots-Tag: noindex, nofollow

/llms.txt
  Content-Type: text/plain; charset=utf-8
  X-Robots-Tag: index, follow

/llms-full.txt
  Content-Type: text/plain; charset=utf-8
  X-Robots-Tag: index, follow

/robots.txt
  Content-Type: text/plain; charset=utf-8
